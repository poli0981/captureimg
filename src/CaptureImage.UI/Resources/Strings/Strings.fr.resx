  <data name="About_Title" xml:space="preserve"><value>À propos de CaptureImage</value></data>
  <data name="About_Tagline" xml:space="preserve"><value>Capture d'écran Windows légère pour les jeux sans touche de capture intégrée.</value></data>
  <data name="About_AppLabel" xml:space="preserve"><value>Application</value></data>
