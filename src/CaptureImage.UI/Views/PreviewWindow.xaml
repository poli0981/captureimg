<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="CaptureImage.UI.Views.PreviewWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="Root"
          Margin="16"
          FlowDirection="{Binding Localization.CurrentFlowDirection, Converter={StaticResource FlowDirectionConverter}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="{Binding Localization[Preview_Title]}"
                       FontFamily="{StaticResource BodyFontFamily}"
                       FontSize="{StaticResource FontSizeTitle}"
                       FontWeight="SemiBold" />
            <TextBlock Margin="0,4,0,0"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                <Run Text="{Binding TargetName}" />
                <Run Text=" — " />
                <Run Text="{Binding Width}" />
                <Run Text="×" />
                <Run Text="{Binding Height}" />
            </TextBlock>
        </StackPanel>

        <!-- Image preview -->
        <Border Grid.Row="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CardCornerRadius}"
                Background="#111111">
            <Image Source="{Binding PngBytes, Converter={StaticResource BytesToBitmapConverter}}"
                   Stretch="Uniform"
                   Margin="8" />
        </Border>

        <!-- Accept / discard -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,12,0,0">
            <TextBlock Text="{Binding Localization[Preview_Prompt]}"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0" />
            <Button x:Name="DiscardButton"
                    Content="{Binding Localization[Preview_Discard]}"
                    Click="OnDiscardClick"
                    MinWidth="100" />
            <Button x:Name="SaveButton"
                    Content="{Binding Localization[Preview_Save]}"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="OnSaveClick"
                    MinWidth="100" />
        </StackPanel>
    </Grid>
</Window>
