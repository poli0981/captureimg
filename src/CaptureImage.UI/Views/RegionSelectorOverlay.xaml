<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="CaptureImage.UI.Views.RegionSelectorOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="Root"
          Background="#80000000"
          PointerPressed="OnPointerPressed"
          PointerMoved="OnPointerMoved"
          PointerReleased="OnPointerReleased"
          KeyDown="OnKeyDown">
        <!-- Background screenshot used as a hint of what is being selected. The image
             below the dim overlay shows through inside the selection rectangle so the
             user sees a "spotlight" effect on the chosen region. -->
        <Image x:Name="BackgroundImage"
               Stretch="Fill"
               Opacity="0.35"
               IsHitTestVisible="False" />

        <!-- Selection rectangle. Visible while the user drags; positioned via Canvas.SetLeft. -->
        <Canvas IsHitTestVisible="False">
            <Border x:Name="SelectionBorder"
                    Visibility="Collapsed"
                    BorderBrush="#FFFF6B35"
                    BorderThickness="2"
                    Background="Transparent">
                <Image x:Name="SelectionImage" Stretch="Fill" />
            </Border>
            <Border x:Name="DimensionBadge"
                    Visibility="Collapsed"
                    Background="#FF1F2937"
                    BorderBrush="#FFFF6B35"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="6,2">
                <TextBlock x:Name="DimensionText"
                           Foreground="White"
                           FontSize="12" />
            </Border>
        </Canvas>

        <!-- Hint shown when no selection is active. -->
        <TextBlock x:Name="HintText"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   Margin="0,32,0,0"
                   FontSize="14"
                   Foreground="White"
                   Opacity="0.85"
                   IsHitTestVisible="False" />
    </Grid>
</Window>
