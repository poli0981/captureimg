<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CaptureImage.ViewModels;assembly=CaptureImage.ViewModels"
        xmlns:nav="clr-namespace:CaptureImage.ViewModels.Navigation;assembly=CaptureImage.ViewModels"
        xmlns:dashboard="clr-namespace:CaptureImage.ViewModels.Dashboard;assembly=CaptureImage.ViewModels"
        xmlns:update="clr-namespace:CaptureImage.ViewModels.Update;assembly=CaptureImage.ViewModels"
        xmlns:settings="clr-namespace:CaptureImage.ViewModels.Settings;assembly=CaptureImage.ViewModels"
        xmlns:about="clr-namespace:CaptureImage.ViewModels.About;assembly=CaptureImage.ViewModels"
        xmlns:views="clr-namespace:CaptureImage.UI.Views"
        xmlns:controls="clr-namespace:CaptureImage.UI.Controls"
        xmlns:conv="clr-namespace:CaptureImage.UI.Converters"
        mc:Ignorable="d"
        x:Class="CaptureImage.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="CaptureImage"
        Width="1200" Height="720"
        MinWidth="1200" MinHeight="720"
        MaxWidth="1200" MaxHeight="720"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        FlowDirection="{Binding Localization.CurrentFlowDirection, Converter={x:Static conv:FlowDirectionConverter.Instance}}">

    <Window.DataTemplates>
        <DataTemplate DataType="dashboard:DashboardViewModel">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="update:UpdateViewModel">
            <views:UpdateView />
        </DataTemplate>
        <DataTemplate DataType="settings:SettingsViewModel">
            <views:SettingsView />
        </DataTemplate>
        <DataTemplate DataType="about:AboutViewModel">
            <views:AboutView />
        </DataTemplate>
    </Window.DataTemplates>

    <Panel>

    <Grid ColumnDefinitions="220,*">

        <!-- Nav rail -->
        <Border Grid.Column="0"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="16,24,16,16">
                    <TextBlock Text="{Binding AppTitle}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                    <TextBlock Text="{Binding AppVersion}"
                               FontSize="11"
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                </StackPanel>

                <!-- Log viewer toggle at the bottom of the nav rail -->
                <Button DockPanel.Dock="Bottom"
                        Command="{Binding ToggleLogViewerCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Margin="8,4,8,16"
                        Padding="12,8"
                        AutomationProperties.Name="{Binding LogToggleTooltip}"
                        ToolTip.Tip="{Binding LogToggleTooltip}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="&#xE9F9;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="16"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding LogToggleLabel}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <ListBox ItemsSource="{Binding NavItems}"
                         SelectedItem="{Binding SelectedNavItem, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0"
                         Margin="8,8,8,8">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="nav:NavItemViewModel">
                            <Grid ColumnDefinitions="32,*" Height="40">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding IconGlyph}"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="16"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Label}"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Content host -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentViewModel}"
                        Margin="0" />

    </Grid>

    <!-- Log viewer drawer — overlays the right 480px of the content grid with a
         200ms slide-in + fade. Always kept in the visual tree so the transitions
         fire on every toggle; IsHitTestVisible + Classes.visible let us collapse
         interaction + drive the animation state from IsLogViewerVisible. -->
    <views:LogViewerView x:Name="LogDrawer"
                         Width="480"
                         HorizontalAlignment="Right"
                         DataContext="{Binding LogViewer}"
                         Classes.visible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsLogViewerVisible}"
                         IsHitTestVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsLogViewerVisible}">
        <views:LogViewerView.Styles>
            <Style Selector="views|LogViewerView">
                <Setter Property="Opacity" Value="0" />
                <Setter Property="RenderTransform" Value="translateX(48px)" />
                <Setter Property="Transitions">
                    <Transitions>
                        <DoubleTransition Property="Opacity" Duration="0:0:0.18" Easing="CircularEaseOut" />
                        <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.22" Easing="CircularEaseOut" />
                    </Transitions>
                </Setter>
            </Style>
            <Style Selector="views|LogViewerView.visible">
                <Setter Property="Opacity" Value="1" />
                <Setter Property="RenderTransform" Value="translateX(0)" />
            </Style>
        </views:LogViewerView.Styles>
    </views:LogViewerView>

    <!-- Toast overlay — anchored bottom-right, floats over the content grid.
         Under RTL FlowDirection Avalonia automatically mirrors Right/Left edges,
         so this ends up bottom-left for ar-SA etc. -->
    <controls:ToastHost ItemsSource="{Binding Toasts}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,20,20"
                        IsHitTestVisible="True" />

    </Panel>

</Window>
