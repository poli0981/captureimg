<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CaptureImage.ViewModels;assembly=CaptureImage.ViewModels"
        xmlns:nav="clr-namespace:CaptureImage.ViewModels.Navigation;assembly=CaptureImage.ViewModels"
        xmlns:dashboard="clr-namespace:CaptureImage.ViewModels.Dashboard;assembly=CaptureImage.ViewModels"
        xmlns:update="clr-namespace:CaptureImage.ViewModels.Update;assembly=CaptureImage.ViewModels"
        xmlns:settings="clr-namespace:CaptureImage.ViewModels.Settings;assembly=CaptureImage.ViewModels"
        xmlns:about="clr-namespace:CaptureImage.ViewModels.About;assembly=CaptureImage.ViewModels"
        xmlns:views="clr-namespace:CaptureImage.UI.Views"
        xmlns:controls="clr-namespace:CaptureImage.UI.Controls"
        xmlns:conv="clr-namespace:CaptureImage.UI.Converters"
        mc:Ignorable="d"
        x:Class="CaptureImage.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="CaptureImage"
        Width="960" Height="600"
        MinWidth="960" MinHeight="600"
        MaxWidth="960" MaxHeight="600"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        FlowDirection="{Binding Localization.CurrentFlowDirection, Converter={x:Static conv:FlowDirectionConverter.Instance}}">

    <Window.DataTemplates>
        <DataTemplate DataType="dashboard:DashboardViewModel">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="update:UpdateViewModel">
            <views:UpdateView />
        </DataTemplate>
        <DataTemplate DataType="settings:SettingsViewModel">
            <views:SettingsView />
        </DataTemplate>
        <DataTemplate DataType="about:AboutViewModel">
            <views:AboutView />
        </DataTemplate>
    </Window.DataTemplates>

    <Panel>

    <Grid ColumnDefinitions="220,*">

        <!-- Nav rail -->
        <Border Grid.Column="0"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="16,24,16,16">
                    <TextBlock Text="{Binding AppTitle}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                    <TextBlock Text="{Binding AppVersion}"
                               FontSize="11"
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                </StackPanel>

                <!-- Log viewer toggle at the bottom of the nav rail -->
                <Button DockPanel.Dock="Bottom"
                        Command="{Binding ToggleLogViewerCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Margin="8,4,8,16"
                        Padding="12,8"
                        AutomationProperties.Name="{Binding Localization[Dashboard_LogToggle]}"
                        ToolTip.Tip="{Binding Localization[Dashboard_LogToggle]}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="&#xE9F9;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="16"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Localization[Nav_LogViewer]}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <ListBox ItemsSource="{Binding NavItems}"
                         SelectedItem="{Binding SelectedNavItem, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0"
                         Margin="8,8,8,8">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="nav:NavItemViewModel">
                            <Grid ColumnDefinitions="32,*" Height="40">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding IconGlyph}"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="16"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Label}"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Content host -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentViewModel}"
                        Margin="0" />

    </Grid>

    <!-- Log viewer drawer — overlays the right 400px when toggled. -->
    <views:LogViewerView Width="400"
                         HorizontalAlignment="Right"
                         DataContext="{Binding LogViewer}"
                         IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsLogViewerVisible}" />

    <!-- Toast overlay — anchored bottom-right, floats over the content grid.
         Under RTL FlowDirection Avalonia automatically mirrors Right/Left edges,
         so this ends up bottom-left for ar-SA etc. -->
    <controls:ToastHost ItemsSource="{Binding Toasts}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,20,20"
                        IsHitTestVisible="True" />

    </Panel>

</Window>
