<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CaptureImage.ViewModels.Dashboard;assembly=CaptureImage.ViewModels"
             xmlns:conv="clr-namespace:CaptureImage.UI.Converters"
             mc:Ignorable="d"
             x:Class="CaptureImage.UI.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

    <UserControl.Resources>
        <conv:BytesToBitmapConverter x:Key="BytesToBitmap" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="24,16,24,16">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,12">
            <StackPanel Grid.Column="0" Orientation="Vertical">
                <TextBlock Text="Dashboard" FontSize="24" FontWeight="SemiBold" />
                <TextBlock Text="Select a target and arm — press the hotkey to capture."
                           Opacity="0.6" FontSize="12" Margin="0,2,0,0" />
            </StackPanel>

            <Button Grid.Column="1"
                    Content="Refresh"
                    Command="{Binding RefreshCommand}"
                    IsEnabled="{Binding !IsLoading}"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0" />

            <Button Grid.Column="2"
                    Content="Arm"
                    Command="{Binding ArmCommand}"
                    IsVisible="{Binding !IsArmed}"
                    VerticalAlignment="Center"
                    Classes="accent"
                    Margin="0,0,8,0" />

            <Button Grid.Column="3"
                    Content="Disarm"
                    Command="{Binding DisarmCommand}"
                    IsVisible="{Binding IsArmed}"
                    VerticalAlignment="Center" />
        </Grid>

        <!-- Target list -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                CornerRadius="4">
            <ListBox ItemsSource="{Binding Targets}"
                     SelectedItem="{Binding SelectedTarget, Mode=TwoWay}"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="4">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="vm:GameTargetViewModel">
                        <Grid ColumnDefinitions="32,*,Auto" Height="40" Margin="4,2">
                            <Image Grid.Column="0"
                                   Source="{Binding IconBytes, Converter={StaticResource BytesToBitmap}}"
                                   Width="24" Height="24"
                                   VerticalAlignment="Center" />

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                <TextBlock Text="{Binding DisplayName}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding ProcessName}"
                                           FontSize="11"
                                           Opacity="0.6"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>

                            <Border Grid.Column="2"
                                    IsVisible="{Binding IsSteamGame}"
                                    Background="#FF6B35"
                                    CornerRadius="10"
                                    Padding="8,2"
                                    VerticalAlignment="Center"
                                    ToolTip.Tip="{Binding SteamBadgeTooltip}">
                                <TextBlock Text="STEAM"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="White" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Armed / capture state -->
        <Border Grid.Row="2"
                Margin="0,12,0,0"
                Padding="12,8"
                CornerRadius="4"
                BorderThickness="1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <Grid ColumnDefinitions="Auto,*">
                <Grid Grid.Column="0" Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,12,0">
                    <!-- Idle dot (gray) -->
                    <Border CornerRadius="5" Background="Gray"
                            IsVisible="{Binding !IsArmed}" />
                    <!-- Armed dot (green) — hidden while capturing -->
                    <Border CornerRadius="5" Background="#3CB371"
                            IsVisible="{Binding IsArmed}" />
                    <!-- Capturing dot (orange) overlays when capture in progress -->
                    <Border CornerRadius="5" Background="#FFA500"
                            IsVisible="{Binding IsCapturing}" />
                </Grid>
                <TextBlock Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>

        <!-- Status bar -->
        <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
            <TextBlock Grid.Column="0"
                       Text="{Binding Targets.Count, StringFormat='{}{0} target(s) visible'}"
                       Opacity="0.6"
                       VerticalAlignment="Center" />
            <TextBlock Grid.Column="1"
                       Text="Loading…"
                       Opacity="0.6"
                       IsVisible="{Binding IsLoading}"
                       VerticalAlignment="Center" />
        </Grid>

    </Grid>

</UserControl>
