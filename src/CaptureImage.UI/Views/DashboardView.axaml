<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CaptureImage.ViewModels.Dashboard;assembly=CaptureImage.ViewModels"
             xmlns:conv="clr-namespace:CaptureImage.UI.Converters"
             mc:Ignorable="d"
             x:Class="CaptureImage.UI.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

    <UserControl.Resources>
        <conv:BytesToBitmapConverter x:Key="BytesToBitmap" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="24,16,24,16">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,12">
            <StackPanel Grid.Column="0" Orientation="Vertical">
                <TextBlock Text="{Binding Localization[Dashboard_Title]}" FontSize="22" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Localization[Dashboard_Subtitle]}"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           FontSize="12" Margin="0,4,0,0" />
            </StackPanel>

            <Button Grid.Column="1"
                    Content="{Binding Localization[Dashboard_Refresh]}"
                    Command="{Binding RefreshCommand}"
                    IsEnabled="{Binding !IsLoading}"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0" />

            <Button Grid.Column="2"
                    Content="{Binding Localization[Dashboard_Arm]}"
                    Command="{Binding ArmCommand}"
                    IsVisible="{Binding !IsArmed}"
                    VerticalAlignment="Center"
                    Classes="accent"
                    Margin="0,0,8,0" />

            <Button Grid.Column="3"
                    Content="{Binding Localization[Dashboard_Disarm]}"
                    Command="{Binding DisarmCommand}"
                    IsVisible="{Binding IsArmed}"
                    VerticalAlignment="Center" />
        </Grid>

        <!-- Target list -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <ListBox ItemsSource="{Binding Targets}"
                         SelectedItem="{Binding SelectedTarget, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="4"
                         IsVisible="{Binding !HasNoTargets}">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="vm:GameTargetViewModel">
                        <Grid ColumnDefinitions="32,*,Auto" Height="40" Margin="4,2">
                            <Image Grid.Column="0"
                                   Source="{Binding IconBytes, Converter={StaticResource BytesToBitmap}}"
                                   Width="24" Height="24"
                                   VerticalAlignment="Center" />

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                <TextBlock Text="{Binding DisplayName}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding ProcessName}"
                                           FontSize="11"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>

                            <Border Grid.Column="2"
                                    IsVisible="{Binding IsSteamGame}"
                                    Background="#FF6B35"
                                    CornerRadius="4"
                                    Padding="8,2"
                                    VerticalAlignment="Center"
                                    ToolTip.Tip="{Binding SteamBadgeTooltip}">
                                <TextBlock Text="STEAM"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="White" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                </ListBox>

                <!-- Empty state: no top-level windows detected. -->
                <TextBlock Text="{Binding EmptyStateText}"
                           IsVisible="{Binding HasNoTargets}"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="24" />
            </Grid>
        </Border>

        <!-- Armed / capture state -->
        <Border Grid.Row="2"
                Margin="0,12,0,0"
                Padding="12,8"
                CornerRadius="8"
                BorderThickness="1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                AutomationProperties.Name="{Binding StatusMessage}">
            <Grid ColumnDefinitions="Auto,*">
                <Grid Grid.Column="0" Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,12,0"
                      AutomationProperties.Name="{Binding StatusMessage}">
                    <!-- Idle dot (gray) -->
                    <Border CornerRadius="5" Background="Gray"
                            IsVisible="{Binding !IsArmed}" />
                    <!-- Armed dot (green) — hidden while capturing -->
                    <Border CornerRadius="5" Background="#3CB371"
                            IsVisible="{Binding IsArmed}" />
                    <!-- Capturing dot (orange) overlays when capture in progress -->
                    <Border CornerRadius="5" Background="#FFA500"
                            IsVisible="{Binding IsCapturing}" />
                </Grid>
                <TextBlock Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>

        <!-- Status bar -->
        <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
            <TextBlock Grid.Column="0"
                       Text="{Binding TargetsCountText}"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       VerticalAlignment="Center" />
            <TextBlock Grid.Column="1"
                       Text="{Binding LoadingText}"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       IsVisible="{Binding IsLoading}"
                       VerticalAlignment="Center" />
        </Grid>

    </Grid>

</UserControl>
