<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CaptureImage.ViewModels.Settings;assembly=CaptureImage.ViewModels"
             xmlns:ctrl="clr-namespace:CaptureImage.UI.Controls"
             xmlns:sys="clr-namespace:System.Globalization;assembly=System.Runtime"
             mc:Ignorable="d"
             x:Class="CaptureImage.UI.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer>
        <StackPanel Margin="24,16" Spacing="18" MaxWidth="620">

            <TextBlock Text="{Binding Localization[Settings_Title]}" FontSize="22" FontWeight="SemiBold" />

            <!-- Language -->
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding Localization[Settings_Language]}" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="12" />
                <ComboBox ItemsSource="{Binding SupportedCultures}"
                          SelectedItem="{Binding SelectedCulture, Mode=TwoWay}"
                          HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate DataType="sys:CultureInfo">
                            <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <!-- Hotkey -->
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding Localization[Settings_Hotkey]}" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="12" />
                <ctrl:HotkeyRecorder DataContext="{Binding Hotkey}" />
                <TextBlock Text="{Binding Localization[Settings_HotkeyHint]}" FontSize="11" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
            </StackPanel>

            <!-- Default format -->
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding Localization[Settings_Format]}" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="12" />
                <ComboBox ItemsSource="{Binding SupportedFormats}"
                          SelectedItem="{Binding DefaultFormat, Mode=TwoWay}"
                          HorizontalAlignment="Stretch" />
            </StackPanel>

            <!-- Quality sliders -->
            <Grid ColumnDefinitions="*,16,*">
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="{Binding Localization[Settings_JpegQuality]}" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="12" />
                    <Slider Minimum="1" Maximum="100" Value="{Binding JpegQuality, Mode=TwoWay}" TickFrequency="10" />
                    <TextBlock Text="{Binding JpegQuality}" FontSize="11" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" HorizontalAlignment="Right" />
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Text="{Binding Localization[Settings_WebpQuality]}" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="12" />
                    <Slider Minimum="1" Maximum="100" Value="{Binding WebpQuality, Mode=TwoWay}" TickFrequency="10" />
                    <TextBlock Text="{Binding WebpQuality}" FontSize="11" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" HorizontalAlignment="Right" />
                </StackPanel>
            </Grid>

            <!-- Output folder -->
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding Localization[Settings_OutputFolder]}" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="12" />
                <Grid ColumnDefinitions="*,8,Auto">
                    <TextBox Grid.Column="0"
                             Text="{Binding OutputDirectory, Mode=TwoWay}"
                             Watermark="{Binding Localization[Settings_OutputFolderDefault]}" />
                    <Button Grid.Column="2"
                            Name="BrowseOutputButton"
                            Content="{Binding Localization[Settings_Browse]}"
                            ToolTip.Tip="{Binding Localization[Settings_BrowseTooltip]}"
                            MinWidth="100" />
                </Grid>
            </StackPanel>

            <!-- File name template -->
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding Localization[Settings_FileNameTemplate]}" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="12" />
                <TextBox Text="{Binding FileNameTemplate, Mode=TwoWay}"
                         FontFamily="Consolas, Courier New, monospace" />
            </StackPanel>

            <!-- Toggles -->
            <StackPanel Spacing="6">
                <CheckBox Content="{Binding Localization[Settings_PreviewBeforeSave]}"
                          IsChecked="{Binding PreviewBeforeSave, Mode=TwoWay}" />
                <CheckBox Content="{Binding Localization[Settings_MinimizeToTray]}"
                          IsChecked="{Binding MinimizeToTray, Mode=TwoWay}" />
                <CheckBox Content="{Binding Localization[Settings_SoundEnabled]}"
                          IsChecked="{Binding SoundEnabled, Mode=TwoWay}" />
            </StackPanel>

            <!-- Import / export / open -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Name="ImportButton" Content="{Binding Localization[Settings_Import]}" />
                <Button Name="ExportButton" Content="{Binding Localization[Settings_Export]}" />
                <Button Content="{Binding Localization[Settings_OpenFile]}"
                        Command="{Binding OpenSettingsFileCommand}" />
            </StackPanel>

            <TextBlock Text="{Binding SettingsFilePath}" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="11" TextWrapping="Wrap" />

        </StackPanel>
    </ScrollViewer>

</UserControl>
