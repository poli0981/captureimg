<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CaptureImage.UI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CaptureImage.UI.Controls"
    mc:Ignorable="d">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Hidden">
        <StackPanel Margin="24,16" Spacing="18" MaxWidth="620" HorizontalAlignment="Left">

            <TextBlock Text="{Binding TitleLabel}"
                       FontFamily="{StaticResource BodyFontFamily}"
                       FontSize="{StaticResource FontSizeTitle}"
                       FontWeight="SemiBold" />

            <!-- Language -->
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding LanguageLabel}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           FontSize="{StaticResource FontSizeSmall}" />
                <ComboBox ItemsSource="{Binding SupportedCultures}"
                          SelectedItem="{Binding SelectedCulture, Mode=TwoWay}"
                          HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <!-- Theme: System / Light / Dark. ItemTemplate binds to ThemeOption.DisplayLabel
                 (already localized in the VM by RebuildThemeOptions). -->
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding ThemeLabel}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           FontSize="{StaticResource FontSizeSmall}" />
                <ComboBox ItemsSource="{Binding SupportedThemes}"
                          SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                          HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayLabel}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <!-- Hotkey: HotkeyRecorder custom control owns the key-capture flow. Bound
                 to the SettingsViewModel.Hotkey child VM (HotkeyBindingViewModel). -->
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding HotkeyLabel}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           FontSize="{StaticResource FontSizeSmall}" />
                <controls:HotkeyRecorder DataContext="{Binding Hotkey}" />
                <TextBlock Text="{Binding HotkeyHint}"
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Default format -->
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding FormatLabel}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           FontSize="{StaticResource FontSizeSmall}" />
                <ComboBox ItemsSource="{Binding SupportedFormats}"
                          SelectedItem="{Binding DefaultFormat, Mode=TwoWay}"
                          HorizontalAlignment="Stretch" />
            </StackPanel>

            <!-- Quality sliders side-by-side -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="{Binding JpegQualityLabel}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontSize="{StaticResource FontSizeSmall}" />
                    <Slider Minimum="1" Maximum="100"
                            Value="{Binding JpegQuality, Mode=TwoWay}"
                            TickFrequency="10" />
                    <TextBlock Text="{Binding JpegQuality}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Right" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Text="{Binding WebpQualityLabel}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontSize="{StaticResource FontSizeSmall}" />
                    <Slider Minimum="1" Maximum="100"
                            Value="{Binding WebpQuality, Mode=TwoWay}"
                            TickFrequency="10" />
                    <TextBlock Text="{Binding WebpQuality}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Right" />
                </StackPanel>
            </Grid>

            <!-- Output folder -->
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding OutputFolderLabel}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           FontSize="{StaticResource FontSizeSmall}" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding OutputDirectory, Mode=TwoWay}"
                             PlaceholderText="{Binding OutputFolderWatermark}" />
                    <Button Grid.Column="1"
                            x:Name="BrowseOutputButton"
                            Content="{Binding BrowseLabel}"
                            ToolTipService.ToolTip="{Binding BrowseTooltip}"
                            MinWidth="100" />
                </Grid>
            </StackPanel>

            <!-- File name template -->
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding FileNameTemplateLabel}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           FontSize="{StaticResource FontSizeSmall}" />
                <TextBox Text="{Binding FileNameTemplate, Mode=TwoWay}"
                         FontFamily="Consolas, Courier New" />
            </StackPanel>

            <!-- Toggles -->
            <StackPanel Spacing="6">
                <CheckBox Content="{Binding PreviewBeforeSaveLabel}"
                          IsChecked="{Binding PreviewBeforeSave, Mode=TwoWay}" />
                <StackPanel Spacing="2">
                    <CheckBox Content="{Binding AutoSwitchOnAltTabLabel}"
                              IsChecked="{Binding AutoSwitchOnAltTab, Mode=TwoWay}" />
                    <TextBlock Text="{Binding AutoSwitchOnAltTabHint}"
                               FontSize="{StaticResource FontSizeCaption}"
                               TextWrapping="Wrap"
                               Margin="28,0,0,0"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <CheckBox Content="{Binding MinimizeToTrayLabel}"
                          IsChecked="{Binding MinimizeToTray, Mode=TwoWay}" />
                <CheckBox Content="{Binding SoundEnabledLabel}"
                          IsChecked="{Binding SoundEnabled, Mode=TwoWay}" />
            </StackPanel>

            <!-- Logging -->
            <StackPanel Spacing="6">
                <TextBlock Text="{Binding LoggingLabel}"
                           FontSize="{StaticResource FontSizeBody}"
                           FontWeight="SemiBold" />
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding LogLevelLabel}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontSize="{StaticResource FontSizeSmall}" />
                    <ComboBox ItemsSource="{Binding SupportedLogLevels}"
                              SelectedItem="{Binding SelectedLogLevel, Mode=TwoWay}"
                              HorizontalAlignment="Stretch" />
                    <TextBlock Text="{Binding LogLevelHint}"
                               FontSize="{StaticResource FontSizeCaption}"
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <!-- Import / export / open settings file -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="ImportButton" Content="{Binding ImportLabel}" />
                <Button x:Name="ExportButton" Content="{Binding ExportLabel}" />
                <Button Content="{Binding OpenFileLabel}"
                        Command="{Binding OpenSettingsFileCommand}" />
            </StackPanel>

            <TextBlock Text="{Binding SettingsFilePath}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       FontSize="{StaticResource FontSizeCaption}"
                       TextWrapping="Wrap" />

        </StackPanel>
    </ScrollViewer>
</Page>
