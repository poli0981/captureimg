<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CaptureImage.ViewModels.Update;assembly=CaptureImage.ViewModels"
             mc:Ignorable="d"
             x:Class="CaptureImage.UI.Views.UpdateView"
             x:DataType="vm:UpdateViewModel">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" Margin="24,16">

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,16">
            <TextBlock Text="{Binding Localization[Update_Title]}" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}">
                <Run Text="{Binding Localization[About_VersionLabel]}" />
                <Run Text=": " />
                <Run Text="{Binding CurrentVersion}" />
            </TextBlock>
        </StackPanel>

        <!-- Available version + release notes -->
        <Border Grid.Row="1"
                IsVisible="{Binding AvailableVersion, Converter={x:Static ObjectConverters.IsNotNull}}"
                Padding="12"
                CornerRadius="8"
                BorderThickness="1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                Margin="0,0,0,12">
            <StackPanel Spacing="6">
                <TextBlock FontWeight="SemiBold">
                    <Run Text="{Binding Localization[Update_NewVersion]}" />
                    <Run Text=" " />
                    <Run Text="{Binding AvailableVersion}" />
                </TextBlock>
                <TextBlock Text="{Binding ReleaseNotes}"
                           IsVisible="{Binding ReleaseNotes, Converter={x:Static ObjectConverters.IsNotNull}}"
                           TextWrapping="Wrap"
                           Opacity="0.85"
                           FontSize="12" />
            </StackPanel>
        </Border>

        <!-- Action buttons + progress -->
        <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,Auto,*" Margin="0,0,0,12">
            <Button Grid.Column="0"
                    Content="{Binding Localization[Update_Check]}"
                    Command="{Binding CheckCommand}"
                    Margin="0,0,8,0" />
            <Button Grid.Column="1"
                    Content="{Binding Localization[Update_Download]}"
                    Command="{Binding DownloadCommand}"
                    Classes="accent"
                    Margin="0,0,8,0" />
            <Button Grid.Column="2"
                    Content="{Binding Localization[Update_Install]}"
                    Command="{Binding InstallCommand}"
                    Classes="accent" />
        </Grid>

        <!-- Progress + status -->
        <StackPanel Grid.Row="3" Spacing="6" Margin="0,0,0,12">
            <ProgressBar Value="{Binding DownloadProgress}"
                         Minimum="0" Maximum="100"
                         IsVisible="{Binding IsBusy}" />
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="12">
                <Run Text="{Binding Localization[Update_Status]}" />
                <Run Text=": " />
                <Run Text="{Binding Status}" />
            </TextBlock>
        </StackPanel>

        <!-- Log section -->
        <Border Grid.Row="4"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10">
            <Grid RowDefinitions="Auto,*">
                <TextBlock Grid.Row="0"
                           Text="{Binding Localization[Update_Log]}"
                           FontWeight="SemiBold"
                           FontSize="12"
                           Margin="0,0,0,8" />
                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding LogLines}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="x:String">
                                <TextBlock Text="{Binding}"
                                           FontFamily="Consolas, Courier New, monospace"
                                           FontSize="11"
                                           TextWrapping="NoWrap" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

    </Grid>

</UserControl>
