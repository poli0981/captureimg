<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CaptureImage.ViewModels.Settings;assembly=CaptureImage.ViewModels"
             mc:Ignorable="d"
             x:Class="CaptureImage.UI.Controls.HotkeyRecorder"
             x:DataType="vm:HotkeyBindingViewModel">

    <UserControl.Styles>
        <!-- Keyboard-focus ring on the BindingField. Fluent's default border is a neutral grey;
             flip it to the accent brush when the control has focus so tab navigation is
             visible and the recording-mode prompt is clearly "waiting on you". -->
        <Style Selector="Border#BindingField:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlHighlightAccentBrush}" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
    </UserControl.Styles>

    <StackPanel Spacing="8">

        <Grid ColumnDefinitions="*,8,Auto,8,Auto">

            <!-- The keyboard-focused surface. Receives KeyDown events while recording; shows the
                 current binding while idle. Focused programmatically from code-behind when
                 IsRecording flips to true. -->
            <Border Grid.Column="0"
                    Name="BindingField"
                    Focusable="True"
                    MinHeight="34"
                    CornerRadius="8"
                    Padding="12,8"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    VerticalAlignment="Center"
                    AutomationProperties.Name="{Binding HotkeyFieldAutomationName}"
                    AutomationProperties.HelpText="{Binding RecorderPromptText}">
                <Grid>
                    <TextBlock Text="{Binding DisplayText}"
                               FontFamily="Consolas, Courier New, monospace"
                               VerticalAlignment="Center"
                               IsVisible="{Binding !IsRecording}" />
                    <TextBlock Text="{Binding RecorderPromptText}"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               FontStyle="Italic"
                               VerticalAlignment="Center"
                               IsVisible="{Binding IsRecording}" />
                </Grid>
            </Border>

            <Button Grid.Column="2"
                    Content="{Binding RecordLabel}"
                    Command="{Binding StartRecordingCommand}"
                    IsVisible="{Binding !IsRecording}"
                    MinWidth="80" />
            <Button Grid.Column="2"
                    Content="{Binding CancelLabel}"
                    Command="{Binding CancelRecordingCommand}"
                    IsVisible="{Binding IsRecording}"
                    MinWidth="80" />

            <Button Grid.Column="4"
                    Content="{Binding ResetLabel}"
                    Command="{Binding ResetToDefaultCommand}"
                    IsVisible="{Binding !IsRecording}"
                    MinWidth="80" />
        </Grid>

        <!-- Validation error — visible only after a rejected commit. -->
        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="#D13438"
                   FontSize="11"
                   TextWrapping="Wrap"
                   IsVisible="{Binding HasError}" />

        <!-- Conflict warning — non-blocking, binding already persisted. -->
        <TextBlock Text="{Binding ConflictWarningText}"
                   Foreground="#C19C00"
                   FontSize="11"
                   TextWrapping="Wrap"
                   IsVisible="{Binding ConflictDetected}" />

    </StackPanel>

</UserControl>
