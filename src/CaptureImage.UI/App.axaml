<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CaptureImage.UI.App"
             RequestedThemeVariant="Default">

    <Application.Styles>
        <FluentTheme />

        <!--
            Visual system conventions (enforced through this file + view-level overrides):

              FontFamily  : Inter (shipped via Avalonia.Fonts.Inter) with Segoe UI fallback;
                            monospace (Consolas/Courier New) only for log entries + hotkey
                            display where fixed glyph width carries meaning.
              FontSize    : 11 (caption) / 12 (small) / 13 (body) / 14 (body-strong) /
                            16 (subtitle) / 22 (title).
              CornerRadius: 8 px for cards, borders, containers. 4 px reserved for inline
                            badges/pills (e.g. Dashboard Steam badge).
              Spacing     : 4 / 8 / 12 / 16 / 24 px scale — every Margin, Padding, Spacing
                            value in a view should snap to one of these.
              Contrast    : secondary text uses SystemControlForegroundBaseMediumBrush,
                            not Opacity="0.6" — the theme brush keeps WCAG AA contrast on
                            both light and dark variants.
        -->

        <!-- Default UI text stack. View-level FontFamily overrides remain for monospace blocks. -->
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="Inter, Segoe UI, sans-serif" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="FontFamily" Value="Inter, Segoe UI, sans-serif" />
        </Style>
        <Style Selector="Button">
            <Setter Property="FontFamily" Value="Inter, Segoe UI, sans-serif" />
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="FontFamily" Value="Inter, Segoe UI, sans-serif" />
        </Style>
        <Style Selector="CheckBox">
            <Setter Property="FontFamily" Value="Inter, Segoe UI, sans-serif" />
        </Style>

        <!-- Visible focus ring on list items. FluentTheme provides selection state styling
             but no keyboard-focus outline; this ensures the :focus-visible pseudo-class
             draws a border in the accent colour when a user tabs through the target list. -->
        <Style Selector="ListBoxItem:focus-visible">
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlHighlightAccentBrush}" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
    </Application.Styles>

</Application>
