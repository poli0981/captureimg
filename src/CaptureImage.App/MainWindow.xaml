<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="CaptureImage.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:CaptureImage.UI.Views"
    xmlns:controls="using:CaptureImage.UI.Controls"
    mc:Ignorable="d">

    <Grid x:Name="Root"
          FlowDirection="{Binding Localization.CurrentFlowDirection, Converter={StaticResource FlowDirectionConverter}}">
        <NavigationView
            x:Name="NavView"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            PaneDisplayMode="Left"
            OpenPaneLength="220"
            MenuItemsSource="{Binding NavItems}"
            SelectedItem="{Binding SelectedNavItem, Mode=TwoWay}"
            SelectionChanged="NavView_SelectionChanged">

            <NavigationView.PaneHeader>
                <StackPanel Margin="12,8,12,8">
                    <TextBlock
                        Text="{Binding AppTitle}"
                        FontFamily="{StaticResource BodyFontFamily}"
                        FontSize="{StaticResource FontSizeTitle}"
                        FontWeight="SemiBold" />
                    <TextBlock
                        Text="{Binding AppVersion}"
                        FontFamily="{StaticResource BodyFontFamily}"
                        FontSize="{StaticResource FontSizeCaption}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Margin="0,4,0,0" />
                </StackPanel>
            </NavigationView.PaneHeader>

            <NavigationView.MenuItemTemplate>
                <DataTemplate>
                    <NavigationViewItem Content="{Binding Label}">
                        <NavigationViewItem.Icon>
                            <FontIcon
                                Glyph="{Binding IconGlyph}"
                                FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                </DataTemplate>
            </NavigationView.MenuItemTemplate>

            <NavigationView.PaneFooter>
                <Button
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Margin="8,4,8,16"
                    Padding="12,8"
                    Background="Transparent"
                    BorderThickness="0"
                    Command="{Binding ToggleLogViewerCommand}"
                    ToolTipService.ToolTip="{Binding LogToggleTooltip}"
                    AutomationProperties.Name="{Binding LogToggleTooltip}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon
                            Glyph="&#xE9F9;"
                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                            FontSize="16" />
                        <TextBlock
                            Text="{Binding LogToggleLabel}"
                            FontFamily="{StaticResource BodyFontFamily}"
                            VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </NavigationView.PaneFooter>

            <Frame x:Name="ContentFrame" />
        </NavigationView>

        <!-- Log viewer drawer overlay — stays in the visual tree always so the slide-in
             Composition animation has something to act on every toggle. Initial collapsed
             state (Offset = +48 px X, Opacity = 0, IsHitTestVisible = false) is set in
             MainWindow.OnRootLoaded; show/hide animations fire from
             OnViewModelPropertyChanged when IsLogViewerVisible flips. -->
        <views:LogViewerView
            x:Name="LogDrawer"
            Width="480"
            HorizontalAlignment="Right"
            DataContext="{Binding LogViewer}" />

        <!-- Toast overlay — anchored bottom-right, floats over content. Inherits the
             root Grid's MainWindowViewModel DataContext; the inner ItemsControl binds to
             its Toasts collection. Under RTL FlowDirection mirrors Right/Left so the
             stack ends up bottom-left for ar-SA culture. -->
        <controls:ToastHost
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0,0,20,20"
            IsHitTestVisible="True" />
    </Grid>
</Window>
